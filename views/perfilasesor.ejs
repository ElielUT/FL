<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perfil de Usuario - UTSJR</title>
    <style>
        :root {
            --primary-green: #00a884;
            --light-green: #4db6ac;
            --dark-green: #00897b;
            --bg-gray: #f2f2f2;
            --text-main: #333;
            --btn-save: linear-gradient(90deg, #4db6ac, #a7ffeb);
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            background-color: #fff;
        }

        /* Header Verde */
        .top-bar {
            background-color: var(--primary-green);
            color: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-top { cursor: pointer; display: flex; align-items: center; gap: 8px; }
        .close-x { font-size: 24px; font-weight: bold; }

        .container {
            max-width: 1100px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h1 { font-size: 2.5em; margin-bottom: 30px; }

        .main-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
        }

        /* Tarjeta de Perfil */
        .profile-card {
            background-color: var(--primary-green);
            border-radius: 20px;
            padding: 30px;
            display: flex;
            align-items: center;
            color: white;
            margin-bottom: 25px;
        }

        .avatar-circle {
            width: 120px;
            height: 120px;
            background-color: #e0e0e0;
            border-radius: 50%;
            margin-right: 25px;
            overflow: hidden;
        }

        .avatar-circle img { width: 100%; height: 100%; object-fit: cover; }

        .badge {
            background-color: #4db6ac;
            padding: 6px 25px;
            border-radius: 8px;
            font-weight: bold;
            display: inline-block;
            margin-top: 10px;
        }

        /* Estilos de Formulario y Vista */
        .info-label { font-weight: bold; margin-top: 20px; display: block; }
        .info-value { margin-bottom: 20px; color: #555; }
        
        input, select {
            width: 100%;
            padding: 12px;
            border-radius: 15px;
            border: none;
            background-color: var(--bg-gray);
            margin-top: 8px;
            font-size: 14px;
        }

        /* Botones */
        .btn-edit-trigger {
            background: linear-gradient(90deg, #4db6ac, #80cbc4);
            border: none;
            padding: 12px 30px;
            border-radius: 12px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 20px;
        }

        .action-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 40px;
        }

        .btn-cancel { background-color: #ccc; border: none; padding: 12px 35px; border-radius: 20px; cursor: pointer; }
        .btn-save { background: var(--btn-save); border: none; padding: 12px 35px; border-radius: 20px; cursor: pointer; font-weight: bold; }

        /* Columna Derecha */
        .slot { background-color: var(--bg-gray); padding: 12px; border-radius: 10px; margin-bottom: 10px; text-align: center; }
        .add-row { display: flex; gap: 10px; align-items: center; margin-bottom: 20px; }
        .plus-icon { color: var(--light-green); font-size: 35px; cursor: pointer; }

        .subject-stack { border-radius: 15px; overflow: hidden; margin-top: 15px; }
        .subject { color: white; padding: 15px; font-weight: bold; }

    </style>
</head>
<body>

    <div class="top-bar">
        <div class="btn-top" onclick="location.reload()"><span>↩</span> Volver</div>
        <div class="close-x">ⓧ</div>
    </div>

    <div class="container">
        <h1>Mi perfil</h1>

        <div class="main-layout">
            
            <div class="left-col">
                <div class="profile-card">
                    <div class="avatar-circle">
                        <img src="https://via.placeholder.com/120" alt="User">
                    </div>
                    <div>
                        <h2 style="margin:0">Eimi Camila Cervantes</h2>
                        <p style="margin:5px 0">eimicaci.ti24@utsjr.edu.mx</p>
                        <div class="badge">Asesor</div>
                    </div>
                </div>

                <div id="view-mode">
                    <span class="info-label">Carrera:</span>
                    <div class="info-value">Tecnologías de la información</div>
                    
                    <span class="info-label">Cuatrimestre:</span>
                    <div class="info-value">3° cuatrimestre</div>

                    <button class="btn-edit-trigger" onclick="toggleEdit(true)">Editar perfil</button>
                </div>

                <div id="edit-mode" style="display: none;">
                    <label class="info-label">Nombre completo:</label>
                    <input type="text" placeholder="Ingrese su nombre">

                    <label class="info-label">Carrera:</label>
                    <input type="text" placeholder="Ingrese su carrera">

                    <label class="info-label">Cuatrimestre:</label>
                    <select>
                        <option>3° cuatrimestre</option>
                        <option>4° cuatrimestre</option>
                    </select>
                </div>
            </div>

            <div class="right-col">
                <h3>Disponibilidad</h3>
                
                <div id="edit-schedule" style="display: none;">
                    <div class="add-row">
                        <input type="text" placeholder="Ej: Lunes 14:00-16:00">
                        <span class="plus-icon">⊕</span>
                    </div>
                </div>

                <div class="schedule-list">
                    <div class="slot">Lunes 14:00-16:00</div>
                    <div class="slot">Miércoles 14:00-16:00</div>
                    <div class="slot">Viernes 14:00-16:00</div>
                </div>

                <div id="view-stats">
                    <div style="display: flex; gap: 40px; margin-top: 30px;">
                        <div style="flex:1">
                            <h3>📂 Materias</h3>
                            <div class="subject-stack">
                                <div class="subject" style="background-color: #4db6ac;">Bases de datos</div>
                                <div class="subject" style="background-color: #26a69a;">Cálculo diferencial</div>
                                <div class="subject" style="background-color: #00897b;">Programación (POO)</div>
                            </div>
                        </div>
                        <div>
                            <h3>🏅 Calificaciones</h3>
                            <div style="font-size: 20px;">🐾🐾🐾🐾🐾</div>
                            <div style="font-size: 48px; font-weight: bold;">5.0</div>
                        </div>
                    </div>
                </div>

                <div id="edit-actions" style="display: none;" class="action-buttons">
                    <button class="btn-cancel" onclick="toggleEdit(false)">Cancelar</button>
                    <button class="btn-save" onclick="toggleEdit(false)">Guardar cambios</button>
                </div>
            </div>

        </div>
    </div>

    <script>
        function toggleEdit(isEditing) {
            const viewMode = document.getElementById('view-mode');
            const editMode = document.getElementById('edit-mode');
            const viewStats = document.getElementById('view-stats');
            const editSchedule = document.getElementById('edit-schedule');
            const editActions = document.getElementById('edit-actions');

            if (isEditing) {
                viewMode.style.display = 'none';
                viewStats.style.display = 'none';
                editMode.style.display = 'block';
                editSchedule.style.display = 'block';
                editActions.style.display = 'flex';
            } else {
                viewMode.style.display = 'block';
                viewStats.style.display = 'flex';
                editMode.style.display = 'none';
                editSchedule.style.display = 'none';
                editActions.style.display = 'none';
            }
        }
    </script>
</body>
</html>