<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mi Perfil - Asesorado</title>
    <link rel="stylesheet" href="styles/estilos.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <header class="header-verde">
        <div style="text-align: center; cursor: pointer;">
            <i class="fas fa-reply"></i><br>
            <small>Volver</small>
        </div>
        <i class="fas fa-times-circle" style="font-size: 1.5rem; cursor: pointer;"></i>
    </header>

    <div class="contenedor-perfil">
        <h1 style="text-align: left; margin-left: 10%; color: #333;">Mi perfil</h1>

        <div class="tarjeta-identidad">
            <div class="avatar-circular">
                <i class="fas fa-user text-gray-400" style="font-size: 3rem; color: #999;"></i>
            </div>
            <div style="text-align: left;">
                <h2 style="margin: 0;">Mariana Rodriguez</h2>
                <p style="margin: 5px 0; font-size: 0.9rem; opacity: 0.9;">marianarp@utsjr.edu.mx</p>
            </div>
        </div>

        <div class="info-academica">
            <p><strong>Carrera:</strong></p>
            <p style="color: #666;">Tecnologías de la información</p>
            
            <p style="margin-top: 20px;"><strong>Cuatrimestre</strong></p>
            <p style="color: #666;">3º cuatrimestre</p>
        </div>

        <button class="btn-editar">Editar perfil</button>
    </div>

</body>
</html>