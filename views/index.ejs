<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LobiFind</title>
    <link rel="stylesheet" href="styles/inicio.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>

<body>
    <main class="login-container">
        <div class="login-card">
            <div class="logo-wrapper">
                <div class="logo-circle">
                    <img src="images/logo_lobo_transparente.png" alt="Logo Lobo" class="wolf-img">
                </div>
            </div>

            <% if (typeof error !=='undefined' ) { %>
                <div class="error-message" style="color: red; text-align: center; margin-bottom: 10px;">
                    <%= error %>
                </div>
                <% } %>

                    <form action="/" method="POST">
                        <div class="input-group">
                            <label>Correo:</label>
                            <input type="text" name="correo" placeholder="Ingrese su usuario" required>
                        </div>

                        <div class="input-group">
                            <label>Contraseña:</label>
                            <input type="password" name="contraseña" placeholder="Ingrese su contraseña" required>
                        </div>

                        <button type="submit" class="btn-login">Iniciar sesión</button>
                    </form>

                    <div class="footer-links">
                        <p>¿Aún no tienes una cuenta? <a href="#">Registrarse</a></p>
                    </div>
        </div>
    </main>

</body>

</html>